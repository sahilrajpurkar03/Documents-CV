# ── LaTeX build artifacts ──────────────────────────────────────────────────
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz

# ── Cover letter output (generated per-user) ──────────────────────────────
cl_*.tex
cl_*.txt
cl_*.pdf

# ── CV output PDF ─────────────────────────────────────────────────────────
cv_*.pdf
main.pdf
main.txt

# ── Personal photo (add your own photo.png) ───────────────────────────────
photo.png

# ── Job search output (timestamped reports) ───────────────────────────────
jobs_*.csv
jobs_*.html

# ── Application log (personal data — never commit) ────────────────────────
log/applications.json

# ── Personal cover letter data (copy from cv_data.example.py and edit) ────
cover_letter/cv_data.py

# ── Python cache ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── Python virtual environments ───────────────────────────────────────────
.venv/
venv/
env/

# ── Temp / editor files ───────────────────────────────────────────────────
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Machine-specific git helper scripts (WSL/NTFS workaround) ────────────
_fix_git.sh
job_search/_install_gh.sh
_gitcmd.sh